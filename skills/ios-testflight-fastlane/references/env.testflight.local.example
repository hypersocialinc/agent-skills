# Copy to <repo-root>/.env.testflight.local and fill in. This file is SECRET —
# add `.env.testflight.local` to .gitignore. The Fastfile loads it via dotenv;
# shell env vars override anything set here.

# --- App Store Connect API key (Users and Access → Integrations → App Store
#     Connect API → generate a key with the "App Manager" role) ---
ASC_API_KEY_ID=XXXXXXXXXX                     # the key's ID (shown next to the key)
ASC_API_ISSUER_ID=00000000-0000-0000-0000-000000000000  # issuer UUID (top of the keys page)
ASC_API_KEY_PATH=/absolute/path/to/AuthKey_XXXXXXXXXX.p8  # the .p8 you downloaded ONCE

# --- The app's numeric App Store Connect id (App Information → "Apple ID").
#     This is a number, NOT your email. ---
ASC_APPLE_ID=1234567890

# --- Signing auth mode ---
#   apple_id : rely on Xcode's signed-in account in your keychain for signing
#              (simplest for a local Mac that already archives from Xcode).
#   api_key  : pass the ASC API key to xcodebuild for signing (use when no
#              interactive Xcode account is available, e.g. CI).
TESTFLIGHT_SIGNING_AUTH_MODE=apple_id
